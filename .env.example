# Turso credentials used by the /api/data serverless function.
# Set these in your Vercel project settings (Settings -> Environment Variables).
# For local development with `vercel dev`, copy this file to `.env` (or `.env.local`).
#
# Use a READ-ONLY token: turso db tokens create <your-db-name> --read-only
TURSO_DATABASE_URL=libsql://your-db-name-org.turso.io
TURSO_AUTH_TOKEN=your-read-only-token
