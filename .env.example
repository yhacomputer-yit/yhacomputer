# Turso credentials used by the serverless API functions.
# Set these in your Vercel project settings (Settings -> Environment Variables).
# For local development, copy this file to `.env` (or `.env.local`).
#
# Keep the public catalog token read-only.
TURSO_DATABASE_URL=libsql://your-db-name-org.turso.io
TURSO_AUTH_TOKEN=your-read-only-token

# Required for contact submissions and admin changes.
TURSO_WRITE_AUTH_TOKEN=your-read-write-token
ADMIN_PASSWORD=choose-a-strong-admin-password
